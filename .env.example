# =============================================================================
# Vexis Agency - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# ---------- Groq API Keys (5 keys rotating across 6 agents) ----------
# Key 1 → Archer (Lead Hunter) — GPT OSS 120B
GROQ_API_KEY_1=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
# Key 2 → Nova (Sales Closer) — GPT OSS 120B
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
# Key 3 → Scout (Research) — GPT OSS 20B
GROQ_API_KEY_3=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
# Key 4 → Echo (Content Writer) — GPT OSS 20B
GROQ_API_KEY_4=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
# Key 5 → Atlas + Sentinel (shared) — GPT OSS 120B / Llama 3.1 8B
GROQ_API_KEY_5=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list for the Python gateway rate limiter
GROQ_API_KEYS=key1,key2,key3,key4,key5

# ---------- Model Configuration ----------
# Reasoning agents: GPT OSS 120B (500 t/sec, 65K completion tokens)
MODEL_ARCHER=openai/gpt-oss-120b
MODEL_NOVA=openai/gpt-oss-120b
MODEL_ATLAS=openai/gpt-oss-120b

# Speed agents: GPT OSS 20B (1000 t/sec, fastest)
MODEL_ECHO=openai/gpt-oss-20b
MODEL_SCOUT=openai/gpt-oss-20b

# Monitor agent: Llama 3.1 8B (560 t/sec, cheapest)
MODEL_SENTINEL=llama-3.1-8b-instant

DEFAULT_MODEL=openai/gpt-oss-120b
FALLBACK_MODEL=openai/gpt-oss-20b
MAX_AGENT_RETRIES=3

# ---------- Database ----------
POSTGRES_USER=vexis
POSTGRES_PASSWORD=vexis_secure_password_change_me
POSTGRES_DB=vexis_agency
DATABASE_URL=postgresql://vexis:vexis_secure_password_change_me@postgres:5432/vexis_agency

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- FastAPI Gateway ----------
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
SECRET_KEY=change-this-to-a-random-secret-key
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------- n8n ----------
N8N_PORT=5678
N8N_BASIC_AUTH_USER=vexis
N8N_BASIC_AUTH_PASSWORD=change_me

# ---------- Chatwoot ----------
CHATWOOT_PORT=3001
CHATWOOT_SECRET=change_me_in_production
CHATWOOT_API_KEY=

# ---------- Mautic ----------
MAUTIC_PORT=8080
MAUTIC_DB_USER=mautic
MAUTIC_DB_PASSWORD=mautic_dev
MAUTIC_DB_ROOT_PASSWORD=root_dev

# ---------- NullClaw ----------
NEXT_PUBLIC_USE_NULLCLAW=false
NEXT_PUBLIC_NULLCLAW_HOST=http://localhost

# ---------- Integrations ----------
NEXT_PUBLIC_CALCOM_URL=
NEXT_PUBLIC_DOCUMENSO_URL=
GPT4FREE_ENABLED=false
